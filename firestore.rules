rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isEnrolled(courseId) {
      return signedIn()
        && exists(/databases/$(database)/documents/courses/$(courseId)/enrollments/$(request.auth.uid));
    }

    function isSruStudentEmail(email) {
      return email is string
        && email.matches('^\\d{13}@student\\.sru\\.ac\\.th$');
    }

    function canCreateOwnEnrollmentFromRoster(courseId, uid) {
      return isSelf(uid)
        && request.resource.data.keys().hasOnly([
          'uid',
          'studentId',
          'displayName',
          'email',
          'section',
          'status',
          'source',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && isSruStudentEmail(request.resource.data.email)
        && request.resource.data.status == 'active'
        && request.resource.data.source == 'student-self-link'
        && exists(/databases/$(database)/documents/courses/$(courseId)/roster/$(request.resource.data.studentId))
        && get(/databases/$(database)/documents/courses/$(courseId)/roster/$(request.resource.data.studentId)).data.email == request.auth.token.email
        && get(/databases/$(database)/documents/courses/$(courseId)/roster/$(request.resource.data.studentId)).data.status == 'active';
    }

    function canReadEnrollment(uid) {
      return isSelf(uid)
        || (signedIn() && resource.data.uid == request.auth.uid)
        || isAdmin();
    }

    function isValidLearningOutcome() {
      return request.resource.data.keys().hasOnly([
          'title',
          'description',
          'bloomLevel',
          'order',
          'isPublished',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.bloomLevel in [
          'remember',
          'understand',
          'apply',
          'analyze',
          'evaluate',
          'create'
        ]
        && request.resource.data.order is number
        && request.resource.data.isPublished is bool;
    }

    function isValidSelfAssessment(courseId, uid) {
      return isSelf(uid)
        && isEnrolled(courseId)
        && request.resource.data.keys().hasOnly([
          'uid',
          'courseId',
          'responses',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.courseId == courseId
        && request.resource.data.responses is map;
    }

    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();

      allow create: if isSelf(uid)
        && request.resource.data.keys().hasOnly([
          'email',
          'displayName',
          'studentId',
          'createdAt',
          'updatedAt'
        ]);

      allow update: if isSelf(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'studentId',
          'updatedAt'
        ]);

      allow delete: if false;
    }

    match /{path=**}/enrollments/{uid} {
      allow read: if canReadEnrollment(uid);
    }

    match /{path=**}/roster/{studentId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.email == request.auth.token.email);
    }

    match /courses/{courseId} {
      allow read: if resource.data.isPublic == true || isAdmin() || isEnrolled(courseId);
      allow write: if isAdmin();

      match /enrollments/{uid} {
        allow read: if canReadEnrollment(uid);
        allow create: if isAdmin() || canCreateOwnEnrollmentFromRoster(courseId, uid);
        allow update, delete: if isAdmin();
      }

      match /roster/{studentId} {
        allow read: if isAdmin()
          || (signedIn() && resource.data.email == request.auth.token.email);
        allow write: if isAdmin();
      }

      match /announcements/{announcementId} {
        allow read: if isAdmin()
          || (isEnrolled(courseId) && resource.data.isPublished == true);
        allow write: if isAdmin();
      }

      match /scoreItems/{scoreItemId} {
        allow read: if isAdmin()
          || (isEnrolled(courseId) && resource.data.isPublished == true);
        allow write: if isAdmin();
      }

      match /learningOutcomes/{outcomeId} {
        allow read: if isAdmin()
          || (isEnrolled(courseId) && resource.data.isPublished == true);
        allow create, update: if isAdmin() && isValidLearningOutcome();
        allow delete: if isAdmin();
      }

      match /selfAssessments/{uid} {
        allow read: if (isSelf(uid) && isEnrolled(courseId)) || isAdmin();
        allow create, update: if isValidSelfAssessment(courseId, uid);
        allow delete: if false;
      }

      match /studentScores/{uid} {
        allow read: if isSelf(uid) || isAdmin();
        allow write: if isAdmin();
      }
    }
  }
}
