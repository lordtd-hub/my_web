{
  "name": "personal-academic-learning-portal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:emulator": "vite --mode emulator --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "qa:emulators": "env PATH=\"/opt/homebrew/opt/openjdk/bin:$PATH\" firebase emulators:start --project demo-personal-academic-learning-portal-local --only auth,firestore",
    "qa:seed": "node scripts/seed-local-emulator.mjs",
    "test": "env PATH=\"/opt/homebrew/opt/openjdk/bin:$PATH\" firebase emulators:exec --project demo-personal-academic-learning-portal-rules-test --only firestore \"node --test tests/firestore.rules.test.mjs\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "firebase": "^12.12.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-tools": "^15.15.0",
    "globals": "^16.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript-eslint": "^8.46.1"
  }
}
