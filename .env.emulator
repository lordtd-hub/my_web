# Local Firebase Emulator config for QA only.
# These values are fake and must not point to a real Firebase project.

VITE_FIREBASE_API_KEY=fake-local-emulator-key
VITE_FIREBASE_AUTH_DOMAIN=demo-personal-academic-learning-portal-local.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-personal-academic-learning-portal-local
VITE_FIREBASE_STORAGE_BUCKET=demo-personal-academic-learning-portal-local.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:local-emulator

VITE_USE_FIREBASE_EMULATORS=true
VITE_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1
VITE_FIREBASE_AUTH_EMULATOR_PORT=9099
VITE_FIRESTORE_EMULATOR_HOST=127.0.0.1
VITE_FIRESTORE_EMULATOR_PORT=8080
